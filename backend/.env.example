DATABASE_URL=postgresql://mailpilot:mailpilot@localhost:5432/mailpilot
AI_PROVIDER=mock
CORS_ORIGINS=http://localhost:5173

# OpenAI-compatible (OpenAI, DeepSeek, Ollama, vLLM, etc.)
# The base_url should include /v1 suffix (e.g. https://api.openai.com/v1)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Anthropic
# The base_url is just the host (SDK appends /v1/messages)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# AI call reliability
AI_REQUEST_TIMEOUT=30
AI_MAX_RETRIES=1
AI_RATE_LIMIT_PER_MINUTE=30

# Auth
JWT_SECRET_KEY=change-me-in-production

# Encryption key for sensitive stored data (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Gmail OAuth
# Local Vite proxy callback: http://localhost:5173/api/gmail/oauth/callback
# Direct backend callback: http://localhost:8000/api/gmail/oauth/callback
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=
GMAIL_SCOPES=openid email https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/gmail.send
GMAIL_OAUTH_SUCCESS_URL=http://localhost:5173/settings?gmail=connected
GMAIL_OAUTH_FAILURE_URL=http://localhost:5173/settings?gmail=error

# Outlook / Microsoft Graph OAuth
# Local Vite proxy callback: http://localhost:5173/api/outlook/oauth/callback
# Direct backend callback: http://localhost:8000/api/outlook/oauth/callback
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REDIRECT_URI=
OUTLOOK_SCOPES=offline_access User.Read Mail.Read Mail.Send
OUTLOOK_OAUTH_SUCCESS_URL=http://localhost:5173/settings?outlook=connected
OUTLOOK_OAUTH_FAILURE_URL=http://localhost:5173/settings?outlook=error
