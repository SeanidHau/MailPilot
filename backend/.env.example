DATABASE_URL=postgresql://mailpilot:mailpilot@localhost:5432/mailpilot
AI_PROVIDER=mock
CORS_ORIGINS=http://localhost:5173

# OpenAI-compatible (OpenAI, DeepSeek, Ollama, vLLM, etc.)
# The base_url should include /v1 suffix (e.g. https://api.openai.com/v1)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Anthropic
# The base_url is just the host (SDK appends /v1/messages)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Auth
JWT_SECRET_KEY=change-me-in-production
